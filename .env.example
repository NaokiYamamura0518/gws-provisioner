# ===== Basic認証 =====
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# ===== Google Workspace =====
# サービスアカウントキーJSON（改行をそのまま貼り付け or 1行に整形）
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ドメインワイド委任で偽装する管理者メールアドレス
GOOGLE_ADMIN_EMAIL=admin@example.com

# Google Workspaceのドメイン（メールアドレス自動生成に使用）
GOOGLE_DOMAIN=example.com

# 新規アカウントの初期パスワード
INITIAL_PASSWORD=Welcome123!

# ===== Slack =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/YYYYY/ZZZZZ

# ===== freee API (経費精算自動化) =====
# freeeアプリのOAuth2認証情報（freee Developersで作成）
FREEE_CLIENT_ID=your_freee_client_id
FREEE_CLIENT_SECRET=your_freee_client_secret
# コールバックURL（Vercelデプロイ後のURL + /api/freee-callback）
FREEE_REDIRECT_URI=https://your-app.vercel.app/api/freee-callback
# freee事業所ID
FREEE_COMPANY_ID=1234567
